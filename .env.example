# =============================================================================
# ARIA — AI Resume Screener
# Environment Variables Reference
#
# DEFAULT (ThetaLogics SaaS): Ollama Cloud + optional Gemini — see OLLAMA_BASE_URL.
# Local Ollama below is OPTIONAL for self-managed / lab deployments only.
#
# Copy this file to .env and fill in the values.
#   - Local dev:  place .env next to docker-compose.yml
#   - Production: place .env next to docker-compose.prod.yml on VPS
#
# Variables marked REQUIRED will cause Docker Compose to abort if missing.
# =============================================================================

# ---------------------------------------------------------------------------
# Environment mode
# ---------------------------------------------------------------------------
# "development" = relaxed defaults (dev JWT secret, CORS wildcards)
# "production"  = strict checks (JWT_SECRET_KEY required, CORS locked)
ENVIRONMENT=development

# ---------------------------------------------------------------------------
# REQUIRED SECRETS (must be set in production)
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=ecb77c4575f6d63fadf832346867c00fbd6888e9090b2d772ec44fe653abc3ad

# Shared secret for service-to-service internal endpoints (voice-agent → backend).
# REQUIRED in production. Generate with: openssl rand -hex 32
INTERNAL_SERVICE_SECRET=REPLACE_WITH_openssl_rand_hex_32

# Strong password for PostgreSQL
POSTGRES_PASSWORD=change-me-in-production

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=aria
POSTGRES_DB=aria_db
# DATABASE_URL is auto-composed in docker-compose.prod.yml from the above.
# For local dev with SQLite, uncomment:
# DATABASE_URL=./resume_screener.db

# ---------------------------------------------------------------------------
# Ollama LLM
# ---------------------------------------------------------------------------
# Default: Ollama Cloud (https://ollama.com) — no local GPU required
# Get your API key from: https://ollama.com/settings/keys
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=2e628a56f9634a198afd35b1d0145384.ujC7ZeJxFHmCbIkLoItYZLHt
OLLAMA_MODEL=gemma4:31b-cloud
# Backend cloud model used for narrative generation and JD profile fallback
OLLAMA_MODEL_BACKEND=gemma4:31b-cloud
#
# For local Ollama (optional — self-managed deployments only), comment out the above and use:
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma4:31b-cloud
# OLLAMA_KEEP_ALIVE=-1  # Keep model always hot in RAM (-1 = never unload)

# Local model for JD profile extraction (disabled by default; cloud is faster)
# Resume skills are extracted via Python (no LLM) for speed
OLLAMA_LOCAL_URL=http://ollama:11434
OLLAMA_MODEL_SKILLS=qwen3.5:2b
OLLAMA_USE_LOCAL_JD_PROFILE=0

# Voice agent uses cloud Ollama for reliability
OLLAMA_BASE_URL_VOICE=https://ollama.com
OLLAMA_MODEL_VOICE=qwen3.5:cloud

# ---------------------------------------------------------------------------
# Google Gemini (optional — overrides Ollama for resume analysis when set)
# Get key from: https://aistudio.google.com/apikey
# ---------------------------------------------------------------------------
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash
# When using Gemini only, skip local Ollama startup wait:
# OLLAMA_STARTUP_REQUIRED=0
# OLLAMA_USE_LOCAL_JD_PROFILE=0
# Main staging stack (docker-compose.main.staging.yml) no longer runs a local Ollama container.

# ---------------------------------------------------------------------------
# LLM Timeouts & Startup
# ---------------------------------------------------------------------------
# Max seconds to wait for the narrative LLM call
# 500s recommended for gemma4:31b-cloud
# 180s sufficient for local models
LLM_NARRATIVE_TIMEOUT=180
# Backend entrypoint waits for Ollama health + model warm before uvicorn
OLLAMA_STARTUP_REQUIRED=1
# Ollama startup polling interval (seconds)
OLLAMA_POLL_INTERVAL_SEC=2
# Max seconds to wait for Ollama to become reachable
OLLAMA_WAIT_TIMEOUT_SEC=120
# Max seconds for the initial model warmup prompt
OLLAMA_WARMUP_TIMEOUT_SEC=300

# ---------------------------------------------------------------------------
# Concurrency & Scaling
# ---------------------------------------------------------------------------
# Batch processing concurrency (max concurrent analyses in a batch)
BATCH_MAX_CONCURRENT=30
# Max concurrent LLM requests (auto-detected: 8 for cloud, 1 for local)
OLLAMA_MAX_CONCURRENT=8
# Queue worker concurrent jobs
QUEUE_MAX_CONCURRENT=10

# ---------------------------------------------------------------------------
# Auth / JWT
# ---------------------------------------------------------------------------
# Short-lived access tokens (revocable via JTI on logout); refreshed via the
# refresh-token cookie. 15 min balances security and UX for the SPA.
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30


# ---------------------------------------------------------------------------
# SMTP Email Configuration (optional - defaults to global env vars)
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ---------------------------------------------------------------------------
# Tenant Email Encryption
# ---------------------------------------------------------------------------
# Fernet key for encrypting tenant SMTP passwords stored in the database.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# ---------------------------------------------------------------------------
# CORS (comma-separated origins)
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://airesume-staging.thetalogics.com

# ---------------------------------------------------------------------------
# Voice Screening (LiveKit + Twilio SIP)
# ---------------------------------------------------------------------------
# LiveKit server credentials (matches keys in livekit.yaml)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Twilio SIP trunk ID (name in livekit.yaml)
SIP_TRUNK_ID=twilio-aria

# Twilio outbound phone number (must be linked to your SIP trunk)
SIP_OUTBOUND_NUMBER=+18722789563

# Voice Agent dispatch URL (used by backend scheduler to trigger calls)
VOICE_AGENT_URL=http://voice-agent:8002

# ---------------------------------------------------------------------------
# Split staging deploy (optional — see docs/VOICE_SPLIT_DEPLOY.md)
# ---------------------------------------------------------------------------
# Main stack:  docker-compose.main.staging.yml  + .env.staging.main.example
# Voice stack: docker-compose.voice.staging.yml + .env.staging.voice.example
# On main:  VOICE_AGENT_URL=http://<voice-vps-ip>:8002
# On voice: ARIA_BACKEND_URL=http://<main-vps>, INTERNAL_SERVICE_SECRET=<shared>
# Voice VPS: MAX_CONCURRENT_CALLS=1, STT_ENGINE=faster_whisper, STT_MODEL=tiny

# Speech service STT engine (monolithic staging defaults to faster_whisper + base model)
STT_ENGINE=faster_whisper
STT_MODEL=base
STT_COMPUTE_TYPE=int8
MAX_CONCURRENT_CALLS=0

# ---------------------------------------------------------------------------
# File Upload Malware Scanning (optional)
# ---------------------------------------------------------------------------
# When CLAMAV_HOST is set, uploaded documents are streamed to a ClamAV daemon
# before processing. Leave blank to disable AV scanning (content-type/magic-byte
# validation still runs). Set CLAMAV_REQUIRED=1 to fail-closed if the scanner
# is unreachable.
CLAMAV_HOST=
CLAMAV_PORT=3310
CLAMAV_REQUIRED=0

# Model fine-tuning (beta). Disabled by default in production. Set to true to
# expose POST /api/training/train. In non-production it defaults to enabled.
TRAINING_ENABLED=

# ============ AI Recruiter ============
# Enable/disable the AI Recruiter interview module
RECRUITER_INTERVIEW_ENABLED=true
