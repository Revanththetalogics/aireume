# Local Development
OLLAMA_BASE_URL=http://localhost:11434
DATABASE_URL=./resume_screener.db

# Production (VPS)
# OLLAMA_BASE_URL=http://ollama:11434
# DATABASE_URL=/data/resume_screener.db

# LLM model (only gemma4:e4b is supported)
OLLAMA_MODEL=gemma4:e4b
OLLAMA_FAST_MODEL=gemma4:e4b

# Ollama keep-alive (-1 = never unload model from RAM)
OLLAMA_KEEP_ALIVE=-1

# PostgreSQL password (REQUIRED in production)
POSTGRES_PASSWORD=change-me-in-production

# JWT secret key (REQUIRED in production)
JWT_SECRET_KEY=change-me-in-production

# Environment: development or production
ENVIRONMENT=development
