# Portainer env for aria-staging-main (LiveKit Cloud voice)
# Copy to Portainer stack environment variables

ENVIRONMENT=staging
CORS_ORIGINS=https://airesume-staging.thetalogics.com

STAGING_POSTGRES_USER=aria_staging
STAGING_POSTGRES_PASSWORD=change-me
STAGING_POSTGRES_DB=aria_staging_db

STAGING_JWT_SECRET_KEY=change-me-openssl-rand-hex-32
INTERNAL_SERVICE_SECRET=change-me-openssl-rand-hex-32
ENCRYPTION_KEY=change-me-fernet-key

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_VOICE=gemini-2.5-flash
GEMINI_MAX_RETRIES=3
GEMINI_NARRATIVE_MAX_TOKENS=2200

OLLAMA_STARTUP_REQUIRED=0
OLLAMA_USE_LOCAL_JD_PROFILE=0
LLM_NARRATIVE_TIMEOUT=120
LLM_INTERVIEW_KIT_TIMEOUT=300
LLM_VOICE_STRATEGY_TIMEOUT=180
PREBUILD_VOICE_STRATEGY=0
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL_BACKEND=qwen2.5:3b
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_MAX_CONCURRENT=4
OLLAMA_BASE_URL_VOICE=https://ollama.com
OLLAMA_MODEL_VOICE=qwen3.5:cloud

BATCH_MAX_CONCURRENT=15
QUEUE_MAX_CONCURRENT=5
RECRUITER_INTERVIEW_ENABLED=true

LIVEKIT_URL=wss://aria-tiq3bh9q.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret-min-32-chars
LIVEKIT_AGENT_NAME=ARIA
ARIA_BACKEND_URL=https://airesume-staging.thetalogics.com

SIP_TRUNK_ID=twilio-aria
SIP_OUTBOUND_NUMBER=+1xxxxxxxxxx
SIP_TERMINATION_ADDRESS=your.pstn.twilio.com
SIP_AUTH_USERNAME=aria-livekit
SIP_AUTH_PASSWORD=change-me
SIP_FROM_HOST=your.pstn.twilio.com
SIP_TRANSPORT=SIP_TRANSPORT_TCP
